# Local development can use http://127.0.0.1:8000. EAS APK builds must use
# the Railway HTTPS backend URL, for example https://<service>.up.railway.app.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Public Supabase client values only. Never add private backend keys here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
